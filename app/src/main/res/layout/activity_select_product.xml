<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentStart="true"
                android:background="@android:color/transparent"
                android:contentDescription="Back"
                android:padding="4dp"
                android:src="@drawable/ic_arrow_back_custom"
                android:tint="@color/textPrimary" />

            <TextView
                android:id="@+id/tvTitle"
                style="@style/ScreenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_toEndOf="@id/btnBack"
                android:layout_toStartOf="@id/btnSaveProduct"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="Select Product" />

            <Button
                android:id="@+id/btnSaveProduct"
                style="@style/PrimaryButton"
                android:layout_width="88dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:backgroundTint="@color/primary"
                android:text="Save" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/layoutRoomInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_background"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvRoomInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Room : Living Room"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWindowsInRoom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Windows in this room:"
                android:textColor="@color/textSecondary"
                android:textSize="14sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutWindowTabs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnWindowTab1"
                        style="@style/PrimaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@color/primary"
                        android:minWidth="120dp"
                        android:text="Window 1" />

                    <Button
                        android:id="@+id/btnWindowTab2"
                        style="@style/PrimaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@color/primary"
                        android:minWidth="120dp"
                        android:text="Window 2" />

                    <Button
                        android:id="@+id/btnWindowTab3"
                        style="@style/PrimaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:backgroundTint="@color/primary"
                        android:minWidth="120dp"
                        android:text="Window 3" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutRecommendedProduct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_background"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvRecommendedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★ RECOMMENDED FOR THIS ROOM"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgRecommendedProduct"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@drawable/input_background"
                    android:contentDescription="Recommended Product"
                    android:padding="6dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvRecommendedProductName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Roller Blind"
                        android:textColor="@color/textPrimary"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRecommendedProductPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="$50 / m² · Best for light control"
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvRecommendedNote"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Suggested for all windows in this room"
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnApplyToAllWindows"
                style="@style/PrimaryButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_gravity="end"
                android:layout_marginTop="14dp"
                android:backgroundTint="@color/primary"
                android:text="Apply to All Windows" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutApplyToWindow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_background"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvApplyWindowTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apply to Window 1 (1200 × 1500 mm)"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioGroupSelectionMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp">

                <RadioButton
                    android:id="@+id/rbUseRecommended"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Use Room’s Recommended Product"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvRecommendedSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:layout_marginTop="8dp"
                    android:text="Roller Blind, $50 / m²"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rbChooseDifferent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Choose Different Product for this Window"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp" />
            </RadioGroup>
        </LinearLayout>

        <TextView
            android:id="@+id/tvOtherProductsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OTHER SUITABLE PRODUCTS"
            android:textColor="@color/textPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOtherProductsHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:text="Visible only if Choose different is selected above"
            android:textColor="@color/textSecondary"
            android:textSize="13sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerProducts"
            android:layout_width="match_parent"
            android:layout_height="420dp"
            android:layout_marginBottom="16dp"
            android:nestedScrollingEnabled="true" />

        <LinearLayout
            android:id="@+id/layoutApplySameSelection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvApplySameSelectionLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Apply same selection to all windows in this room"
                    android:textColor="@color/textPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Switch
                    android:id="@+id/switchApplySameSelection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvApplySameSelectionHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="This will update the other windows in this room with the same product"
                android:textColor="@color/textSecondary"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>