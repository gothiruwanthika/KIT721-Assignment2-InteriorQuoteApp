<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentStart="true"
                android:background="@android:color/transparent"
                android:contentDescription="Back"
                android:padding="4dp"
                android:src="@drawable/ic_arrow_back_custom"
                android:tint="@color/textPrimary" />

            <TextView
                android:id="@+id/tvTitle"
                style="@style/ScreenTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="New Window" />

            <Button
                android:id="@+id/btnSaveWindow"
                style="@style/PrimaryButton"
                android:layout_width="88dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:backgroundTint="@color/primary"
                android:text="Save" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                style="@style/FormLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Window Name *" />

            <EditText
                android:id="@+id/etWindowName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_background"
                android:hint="e.g., Window 1"
                android:inputType="textCapWords"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textHint"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvWindowNameError"
                style="@style/ErrorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Window name is required" />

            <TextView
                style="@style/FormLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Width (mm) *" />

            <EditText
                android:id="@+id/etWindowWidth"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_background"
                android:hint="e.g., 1200"
                android:inputType="number"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textHint"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvWindowWidthError"
                style="@style/ErrorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Width is required" />

            <TextView
                style="@style/FormLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Height (mm) *" />

            <EditText
                android:id="@+id/etWindowHeight"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_background"
                android:hint="e.g., 1500"
                android:inputType="number"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textHint"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvWindowHeightError"
                style="@style/ErrorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Height is required" />

            <TextView
                style="@style/FormLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selected Product *" />

            <LinearLayout
                android:id="@+id/layoutSelectedProduct"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <TextView
                    android:id="@+id/tvSelectedProduct"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="No product selected"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvProductArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/textHint"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSelectedProductError"
                style="@style/ErrorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product is required" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>