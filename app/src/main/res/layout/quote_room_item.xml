<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/card_background"
    android:elevation="3dp"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <CheckBox
            android:id="@+id/cbIncludeRoom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvRoomName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Living Room"
            android:textColor="@color/textPrimary"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvWindowLines"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Window 1 - Standard Roller Blind - White - 1200mm × 1500mm - $90"
        android:textColor="@color/textPrimary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvFloorSpaceLines"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Floor Space 1 - Premium Wool Carpet - Charcoal - 3500mm × 4000mm - $1400"
        android:textColor="@color/textPrimary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvRoomLabourCost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Labour Cost: $50"
        android:textColor="@color/textSecondary"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRoomTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Room Total: $1540"
        android:textColor="@color/primary"
        android:textSize="20sp"
        android:textStyle="bold" />

</LinearLayout>