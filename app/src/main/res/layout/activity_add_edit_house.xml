<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="Back" />

            <TextView
                android:id="@+id/tvFormTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="New House"
                android:textSize="28sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSaveHouse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Save" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customer Name *"
            android:textStyle="bold"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/etCustomerName"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="e.g., Gothami Jayasingha"
            android:inputType="textPersonName"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvCustomerNameError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customer name is required"
            android:textColor="#D32F2F"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Number *"
            android:textStyle="bold"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/etContactNumber"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="e.g., 0403346783"
            android:inputType="phone"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvContactNumberError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact number is required"
            android:textColor="#D32F2F"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address Line 1 *"
            android:textStyle="bold"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/etAddressLine1"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="e.g., 12 Collins St, Hobart"
            android:inputType="textPostalAddress"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvAddressLine1Error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address line 1 is required"
            android:textColor="#D32F2F"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address Line 2 (Optional)"
            android:textStyle="bold"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/etAddressLine2"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="e.g., Floor 4"
            android:inputType="textPostalAddress"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="City"
                    android:textStyle="bold"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/etCity"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:hint="e.g., West Hobart"
                    android:inputType="textCapWords"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Postal Code"
                    android:textStyle="bold"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/etPostalCode"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:hint="e.g., 7000"
                    android:inputType="number"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Address (Optional)"
            android:textStyle="bold"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="e.g., abc@gmail.com"
            android:inputType="textEmailAddress"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>