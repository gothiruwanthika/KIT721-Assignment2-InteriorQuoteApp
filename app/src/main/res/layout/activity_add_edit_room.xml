<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentStart="true"
                android:background="@android:color/transparent"
                android:contentDescription="Back"
                android:padding="4dp"
                android:src="@drawable/ic_arrow_back_custom"
                android:tint="@color/textPrimary" />

            <TextView
                android:id="@+id/tvTitle"
                style="@style/ScreenTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="New Room" />

            <Button
                android:id="@+id/btnSaveRoom"
                style="@style/PrimaryButton"
                android:layout_width="88dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:backgroundTint="@color/primary"
                android:text="Save" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                style="@style/FormLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Room Name *" />

            <EditText
                android:id="@+id/etRoomName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_background"
                android:hint="e.g., Living Room"
                android:inputType="textCapWords"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textHint"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvRoomNameError"
                style="@style/ErrorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Room name is required" />

            <TextView
                style="@style/FormLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Labour Cost (AUD) *" />

            <EditText
                android:id="@+id/etLabourCost"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_background"
                android:hint="e.g., 50"
                android:inputType="numberDecimal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textHint"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvLabourCostError"
                style="@style/ErrorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Labour cost is required" />

            <TextView
                style="@style/FormLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Room Photo" />

            <LinearLayout
                android:id="@+id/layoutPhotoPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_background"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/imgRoomPhotoPlaceholder"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:contentDescription="Room Photo Placeholder"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera" />

                <TextView
                    android:id="@+id/tvNoPhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="No photo selected"
                    android:textColor="@color/textSecondary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnAddPhoto"
                    style="@style/PrimaryButton"
                    android:layout_width="140dp"
                    android:layout_height="44dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/primary"
                    android:text="Add Photo" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>