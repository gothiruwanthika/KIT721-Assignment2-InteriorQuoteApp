<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="Back" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btnBack"
                android:layout_toStartOf="@id/btnSaveFloorSpace"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="Floor Space Name"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSaveFloorSpace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Save" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Floor Space Name *"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etFloorSpaceName"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:hint="e.g., Floor 1"
            android:inputType="textCapWords" />

        <TextView
            android:id="@+id/tvFloorSpaceNameError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Floor space name is required"
            android:textColor="#D32F2F"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Width (mm) *"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etFloorSpaceWidth"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:hint="e.g., 1200"
            android:inputType="number" />

        <TextView
            android:id="@+id/tvFloorSpaceWidthError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Width is required"
            android:textColor="#D32F2F"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Length (mm) *"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etFloorSpaceLength"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:hint="e.g., 1500"
            android:inputType="number" />

        <TextView
            android:id="@+id/tvFloorSpaceLengthError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Length is required"
            android:textColor="#D32F2F"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selected product *"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/layoutSelectedProduct"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/edit_text"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/tvSelectedProduct"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No product selected"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvProductArrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="28sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSelectedProductError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Product is required"
            android:textColor="#D32F2F"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>