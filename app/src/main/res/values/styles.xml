<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ScreenTitle">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/textPrimary</item>
    </style>

    <style name="SectionTitle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="FormLabel">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <style name="ErrorText">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/error</item>
        <item name="android:visibility">gone</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="PrimaryButton">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="DangerButton">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">15sp</item>
        <item name="android:backgroundTint">@color/error</item>
    </style>
</resources>